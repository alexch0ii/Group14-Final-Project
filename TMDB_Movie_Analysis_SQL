    "query = \"\"\"\n",
    "WITH ranked_movies AS (\n",
    "    SELECT\n",
    "        c.primary_genre,\n",
    "        c.title,\n",
    "        c.language_group,\n",
    "        c.runtime_group,\n",
    "        f.budget,\n",
    "        f.revenue,\n",
    "        f.profit,\n",
    "        f.roi,\n",
    "        RANK() OVER (\n",
    "            PARTITION BY c.primary_genre\n",
    "            ORDER BY f.roi DESC\n",
    "        ) AS genre_roi_rank\n",
    "    FROM vw_movie_core c\n",
    "    JOIN vw_movie_finance f\n",
    "      ON c.movie_id = f.movie_id\n",
    "    WHERE c.status = 'Released'\n",
    "      AND f.budget IS NOT NULL\n",
    "      AND f.revenue IS NOT NULL\n",
    "      AND f.budget > 0\n",
    ")\n",
    "SELECT\n",
    "    primary_genre,\n",
    "    title,\n",
